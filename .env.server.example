# Copy to ".env.server" (never commit real secrets). Restart: npm run server
#
# --- Pick ONE scenario for FRONTEND_ORIGIN (must match the URL you open in the browser) ---
# A) Laptop browser only:        FRONTEND_ORIGIN=http://localhost:8080
# B) Phone on same Wi‑Fi:        FRONTEND_ORIGIN=http://YOUR_PC_LAN_IP:8080  (e.g. http://192.168.1.8:8080)
# If you use (A) and (B) often, switch FRONTEND_ORIGIN when you switch device, or run two terminals is awkward—
# simplest is: web dev = localhost origin; mobile test = change to LAN IP and restart server.
#
PORT=3001
# Behind nginx/Caddy with HTTPS: set so OAuth redirect uses https:// (see DEPLOY.md)
# TRUST_PROXY=1

FRONTEND_ORIGIN=http://localhost:8080

# Kite Connect (optional; needed for live Kite-backed quotes)
KITE_API_KEY=
KITE_API_SECRET=
# Must match the redirect URL in your Kite developer app settings
KITE_REDIRECT_URL=http://127.0.0.1:3001/kite/callback

JWT_SECRET=replace_with_strong_secret
DEFAULT_VIRTUAL_BALANCE_INR=10000000

# Optional: admin-only features (must match VITE_ADMIN_EMAIL in .env)
ADMIN_EMAIL=

# Google OAuth (optional). OAuth 2.0 Web client in Google Cloud Console.
# GOOGLE_REDIRECT_URI must match "Authorized redirect URIs" exactly (http vs https, localhost vs 127.0.0.1).
# You can register multiple URIs in Google Console; this file must use one of them.
# Local default:
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback
