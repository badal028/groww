VITE_TWELVE_DATA_API_KEY=
VITE_MARKET_DATA_PROVIDER=mock
# Backend URL the browser calls. Laptop: http://127.0.0.1:3001 — Phone on Wi‑Fi: http://YOUR_PC_LAN_IP:3001
VITE_MARKET_DATA_API_BASE=http://127.0.0.1:3001
# Google Analytics 4 — optional; same ID as GA “Install manually” (SPA loads via src/lib/analytics.ts)
# VITE_GA_MEASUREMENT_ID=G-5J8XBNM3SN
# Optional; must match ADMIN_EMAIL in .env.server for admin UI
# VITE_ADMIN_EMAIL=
# Optix Trades — official links (sidebar + /about-optix + /press). Use full URLs.
# VITE_OPTIX_TELEGRAM_URL=https://t.me/your_channel
# VITE_OPTIX_INSTAGRAM_URL=https://www.instagram.com/your_handle
